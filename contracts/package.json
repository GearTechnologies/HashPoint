{
  "name": "@hashpoint/contracts",
  "version": "1.0.0",
  "description": "HashPoint smart contracts for HashKey Chain",
  "private": true,
  "scripts": {
    "build": "npx hardhat compile",
    "test": "npx hardhat test",
    "deploy:testnet": "npx hardhat run scripts/deploy.ts --network hashkeyTestnet",
    "deploy:mainnet": "npx hardhat run scripts/deploy.ts --network hashkeyMainnet",
    "lint": "npx solhint 'contracts/**/*.sol'"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-ignition": "^0.15.16",
    "@nomicfoundation/hardhat-ignition-ethers": "^0.15.17",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.1.3",
    "@nomicfoundation/ignition-core": "^0.15.15",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.20",
    "@types/mocha": "^10.0.10",
    "chai": "^4.5.0",
    "dotenv": "^16.6.1",
    "ethers": "^6.16.0",
    "hardhat": "^2.22.0",
    "hardhat-gas-reporter": "^1.0.8",
    "keccak256": "^1.0.6",
    "merkletreejs": "^0.4.1",
    "solhint": "^4.0.0",
    "solidity-coverage": "^0.8.17",
    "ts-node": "^10.9.0",
    "typechain": "^8.3.2",
    "typescript": "^5.0.0"
  }
}
