# HashPoint Environment Configuration
# Copy to .env and fill in values

# Deployment
DEPLOYER_PRIVATE_KEY=
HASHKEY_MAINNET_RPC=https://mainnet.hsk.xyz
HASHKEY_TESTNET_RPC=https://testnet.hsk.xyz
FEE_RECIPIENT_ADDRESS=

# Relay service
RELAY_WALLET_PRIVATE_KEY=

# Database / Cache
DATABASE_URL=postgresql://user:password@localhost:5432/hashpoint
REDIS_URL=redis://localhost:6379

# Frontend (Next.js)
NEXT_PUBLIC_ESCROW_ADDRESS=
NEXT_PUBLIC_NONCE_REGISTRY_ADDRESS=
NEXT_PUBLIC_MERCHANT_REGISTRY_ADDRESS=
NEXT_PUBLIC_CHAIN_ID=177
NEXT_PUBLIC_RPC_URL=https://mainnet.hsk.xyz
NEXT_PUBLIC_MERCHANT_NAME=My Shop
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_USDT_ADDRESS=
